<Window
    x:Class="Vulcan.SolidWorksClient.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Vulcan AI 建模助手"
    Width="500"
    Height="300"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,10"
            FontSize="14"
            FontWeight="Bold"
            Text="请输入你的建模需求" />

        <TextBox
            x:Name="TxtPrompt"
            Grid.Row="1"
            Padding="5"
            BorderBrush="#CCCCCC"
            BorderThickness="1"
            FontSize="12"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />

        <Button
            x:Name="BtnGenerate"
            Grid.Row="2"
            Margin="0,15,0,0"
            Padding="30,8"
            HorizontalAlignment="Center"
            Click="BtnGenerate_Click"
            Content="一键生成模型"
            FontSize="14" />
    </Grid>
</Window>